{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@adaptlink/shared-types": ["packages/shared-types/src/index.ts"],
      "@adaptlink/post-launch-seller": ["modules/post-launch-seller/src/index.ts"],
      "@adaptlink/shopee-connector": ["packages/shopee-connector/src/index.ts"],
      "@adaptlink/ai-core": ["packages/ai-core/src/index.ts"],
      "@adaptlink/utils": ["packages/utils/src/index.ts"]
    }
  }
}
