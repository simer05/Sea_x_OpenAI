{
  "name": "@acp-sea/demo-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shopee-inspired demo UI with AI shopping agent for ACP-SEA Bridge.",
  "scripts": {
    "predev": "pnpm --dir \"../member 2/marketplace-runtime\" build",
    "dev": "concurrently -n ui,api -c cyan,magenta \"vite --host 127.0.0.1\" \"tsx server/agentApi.ts\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:api": "tsx server/agentApi.ts",
    "build": "tsc -p tsconfig.json && vite build && node scripts/copy-dashboards.mjs",
    "start:api": "tsx server/agentApi.ts",
    "preview": "vite preview --host 127.0.0.1",
    "test:smoke": "tsx server/smokeDemo.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.561.0",
    "openai": "^6.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
